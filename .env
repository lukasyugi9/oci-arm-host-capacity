OCI_REGION=ap-batam-1
OCI_USER_OCID=${{ secrets.OCI_USER_OCID }}
OCI_TENANCY_OCID=${{ secrets.OCI_TENANCY_OCID }}
OCI_COMPARTMENT_OCID=${{ secrets.OCI_COMPARTMENT_OCID }}
OCI_FINGERPRINT=${{ secrets.OCI_FINGERPRINT }}
OCI_PRIVATE_KEY=${{ secrets.OCI_PRIVATE_KEY }}

# Spesifikasi Server ARM Gratis Maksimal
OCI_OCPUS=4
OCI_MEMORY_IN_GBS=24

# Ukuran Harddisk (Sesuai rencana kita sebelumnya)
OCI_BOOT_VOLUME_SIZE_IN_GBS=100

# Nama Server saat jadi nanti
OCI_DISPLAY_NAME=openclaw-server
